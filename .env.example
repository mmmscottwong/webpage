# Copy this file to .env and fill in your values.
# Never commit .env or put real secrets in this repo.

# Google (OAuth uses credentials.json + token.json; no keys here unless you need extra config)
# GA4 property ID for reporting (find via: py tools/google_ga4.py --list-properties)
# GA4_PROPERTY_ID=123456789

# Default folder for Drive uploads (e.g. Shared drives\Sales Department\00_Inbox\11_Inbox_Scott).
# Get ID from the folder URL in Drive. Used when --folder-id is not specified.
# GOOGLE_DRIVE_DEFAULT_FOLDER_ID=your_folder_id_here

# WordPress (tools/wordpress_api.py) – site URL, admin user, Application Password from Users → Profile
# WORDPRESS_URL=https://your-store.com
# WORDPRESS_USER=admin_username
# WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# WooCommerce (tools/woocommerce_api.py) – from WooCommerce → Settings → Advanced → REST API
# WOOCOMMERCE_CONSUMER_KEY=ck_xxxxxxxxxxxx
# WOOCOMMERCE_CONSUMER_SECRET=cs_xxxxxxxxxxxx

# HubSpot (tools/hubspot_api.py) – Private App access token from Settings → Integrations → Private Apps
# HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# n8n (tools/n8n_api.py) – base URL and API key from Settings → n8n API (REST API not on free trial)
# N8N_BASE_URL=https://your-n8n-instance.com
# N8N_API_KEY=your-api-key

# Meta Insights (tools/meta_insights_api.py) – System User token from Meta Business Suite → Settings → System Users
# META_SYSTEM_USER_TOKEN=your_system_user_token
# META_PAGE_ID=your_facebook_page_id
# META_IG_BUSINESS_ID=your_instagram_business_account_id
# Meta Audiences (tools/meta_audiences_api.py) – Ad Account ID from Ads Manager → Account Settings (e.g. act_123456789)
# META_AD_ACCOUNT_ID=act_123456789
# META_GRAPH_API_VERSION=v19.0

# Email Booking Agent – calendar and availability settings
# BOOKING_CALENDAR_ID=your_google_calendar_id@group.calendar.google.com
# BOOKING_TIMEZONE=Asia/Hong_Kong
# BOOKING_WORKING_HOURS_START=09:00
# BOOKING_WORKING_HOURS_END=18:00
# BOOKING_MEETING_LENGTH_MIN=60
# BOOKING_MIN_NOTICE_HOURS=24
# BOOKING_MAX_DAYS_AHEAD=14
# BOOKING_PROPOSE_SLOTS=3
# BOOKING_AGENT_SECRET=your_http_server_auth_token
# BOOKING_LOG_SHEET_ID=your_google_sheet_id
# BOOKING_LOG_SHEET_RANGE=Sheet1!A:Z
# MY_EMAIL=your@email.com

# GitHub (optional – for API or Actions; never commit tokens)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx
